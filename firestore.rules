rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Security primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserEmail() {
      return request.auth.token.email;
    }

    // Verifies whether the logged-in user is allowed to access and use the simulator
    function isAllowedUser() {
      return isEmailVerified() && (
        getUserEmail() == 'diegofmartins@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(getUserEmail())) && 
         get(/databases/$(database)/documents/users/$(getUserEmail())).data.allowed == true)
      );
    }

    // Verifies whether the logged-in user represents an Administrator
    function isAdmin() {
      return isEmailVerified() && (
        getUserEmail() == 'diegofmartins@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(getUserEmail())) && 
         get(/databases/$(database)/documents/users/$(getUserEmail())).data.role == 'admin')
      );
    }

    // 3. Match collection rules
    match /users/{userEmail} {
      // Any authenticated and authorized user can read other users (e.g., to load listings)
      allow read: if isAllowedUser();
      
      // Only Administrators can create, update, or remove users
      allow create, update, delete: if isAdmin();
    }

    match /simulations/{simulationId} {
      // Any authorized user can read simulations (shared workspace)
      allow read, list: if isAllowedUser();
      
      // Any authorized user can write or delete simulations
      allow create, update, delete: if isAllowedUser();
    }
  }
}
